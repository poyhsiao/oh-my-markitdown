# 輸入/輸出文件
input/*
output/*

# 保留 .gitkeep 以保留目錄結構
!input/.gitkeep
!output/.gitkeep

# Docker
*.log
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/

# API
api/__pycache__/
*.pyc

# Editor swaps
*.swp
*.swo
*~
.README.md.swp
.Dockerfile.swp

# Docker
.docker-compose.yml.swp

# Environment variables (keep .env.example, ignore .env)
.env
.env.local
.env.*.local
