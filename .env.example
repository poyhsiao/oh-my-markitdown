# MarkItDown API 環境變數配置範例
# 複製此檔案為 .env 並根據需求修改

# ===========================================
# API 端口配置
# ===========================================
# 對外暴露的端口（預設：51083）
API_PORT=51083

# API 內部監聽端口（容器內，預設：8000）
API_PORT_INTERNAL=8000

# API 監聽地址（預設：0.0.0.0）
API_HOST=0.0.0.0

# 調試模式（true/false，預設：false）
API_DEBUG=false

# Worker 數量（預設：1）
API_WORKERS=1

# ===========================================
# 目錄配置
# ===========================================
# 數據持久化目錄（預設：./data）
DATA_DIR=./data

# 輸入文件目錄（預設：./input）
INPUT_DIR=./input

# 輸出文件目錄（預設：./output）
OUTPUT_DIR=./output

# ===========================================
# OCR 預設配置
# ===========================================
# 預設 OCR 語言（預設：chi_tra+eng）
# 支援：chi_tra, chi_sim, eng, jpn, kor, tha, vie
# 使用 + 組合多種語言，例如：chi_tra+eng+jpn
DEFAULT_OCR_LANG=chi_tra+eng

# 預設是否啟用插件（true/false，預設：false）
ENABLE_PLUGINS_BY_DEFAULT=false

# ===========================================
# 上傳限制
# ===========================================
# 最大上傳文件大小（字節，預設：52428800 = 50MB）
MAX_UPLOAD_SIZE=52428800

# ===========================================
# 資源限制
# ===========================================
# 記憶體限制（預設：2G）
MEMORY_LIMIT=2G

# 記憶體保留（預設：512M）
MEMORY_RESERVE=512M

# CPU 限制（預設：2.0）
CPU_LIMIT=2.0

# CPU 保留（預設：0.5）
CPU_RESERVE=0.5

# ===========================================
# 健康檢查配置
# ===========================================
# 健康檢查間隔（預設：30s）
HEALTHCHECK_INTERVAL=30s

# 健康檢查超時（預設：10s）
HEALTHCHECK_TIMEOUT=10s

# 健康檢查重試次數（預設：3）
HEALTHCHECK_RETRIES=3

# 健康檢查啟動寬限期（預設：40s）
HEALTHCHECK_START_PERIOD=40s

# ===========================================
# 日誌配置
# ===========================================
# 日誌文件最大大小（預設：10m）
LOG_MAX_SIZE=10m

# 日誌文件最大數量（預設：3）
LOG_MAX_FILE=3

# ===========================================
# OpenAI 配置（可選，用於高品質 OCR）
# ===========================================
# OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI API Base URL（可替換為其他兼容服務）
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 模型（預設：gpt-4o）
OPENAI_MODEL=gpt-4o

# ===========================================
# Azure Document Intelligence 配置（可選）
# ===========================================
# Azure Document Intelligence 端點
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Azure Document Intelligence Key
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-key-here
