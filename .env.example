# MarkItDown API 環境變數配置範例
# ===========================================
# 使用說明：
# 1. 複製此檔案為 .env：cp .env.example .env
# 2. 根據需求編輯 .env 文件
# 3. 重啟服務：docker compose restart
#
# 注意：.env 文件包含敏感信息，請勿提交到 Git！

# ===========================================
# 🌐 API 端口配置
# ===========================================

# 對外暴露的端口（瀏覽器/客戶端訪問的端口）
# 預設：51083
# 範例：API_PORT=8080
API_PORT=51083

# API 內部監聽端口（容器內部，通常不需要修改）
# 預設：8000
API_PORT_INTERNAL=8000

# API 監聽地址（0.0.0.0 表示允許所有網絡接口訪問）
# 預設：0.0.0.0
API_HOST=0.0.0.0

# 調試模式（true/false）
# 開啟後會顯示詳細錯誤信息
# 預設：false（生產環境建議關閉）
API_DEBUG=false

# Worker 數量（處理並發請求的工作進程數）
# 預設：1
# 建議：CPU 核心數 或 CPU 核心數 * 2
API_WORKERS=1

# ===========================================
# 📁 目錄配置
# ===========================================

# 數據持久化目錄（用於存儲臨時數據、緩存等）
# 預設：./data
# 可以是絕對路徑或相對於專案目錄的相對路徑
DATA_DIR=./data

# 輸入文件目錄（批量處理時放置待轉換的文件）
# 預設：./input
INPUT_DIR=./input

# 輸出文件目錄（批量處理時存放轉換後的 Markdown）
# 預設：./output
OUTPUT_DIR=./output

# ===========================================
# 🔤 OCR 預設配置
# ===========================================

# 預設 OCR 語言（當 API 請求未指定時使用）
# 支援的語言代碼：
#   - chi_tra: 繁體中文
#   - chi_sim: 簡體中文
#   - eng: 英文
#   - jpn: 日文
#   - kor: 韓文
#   - tha: 泰文
#   - vie: 越南文
#
# 使用 + 符號組合多種語言，例如：
#   - chi_tra+eng: 繁體中文 + 英文（推薦）
#   - chi_sim+eng: 簡體中文 + 英文
#   - chi_tra+jpn+kor+eng: 東北亞多語言
#   - chi_tra+tha+vie+eng: 東南亞多語言
#
# 預設：chi_tra+eng
DEFAULT_OCR_LANG=chi_tra+eng

# 預設是否啟用插件（OCR 等功能）
# true: 預設啟用 OCR
# false: 預設不啟用（可透過 API 參數覆蓋）
# 預設：false
ENABLE_PLUGINS_BY_DEFAULT=false

# ===========================================
# 📤 上傳限制
# ===========================================

# 最大上傳文件大小（字節）
# 預設：52428800 (50MB)
# 範例：
#   10MB = 10485760
#   50MB = 52428800
#   100MB = 104857600
#   500MB = 524288000
MAX_UPLOAD_SIZE=52428800

# ===========================================
# 💻 資源限制
# ===========================================

# 記憶體限制（Docker 容器最大使用記憶體）
# 預設：2G
# 範例：512M, 1G, 2G, 4G
MEMORY_LIMIT=2G

# 記憶體保留（容器保證可用的最小記憶體）
# 預設：512M
MEMORY_RESERVE=512M

# CPU 限制（最大可用 CPU 核心數）
# 預設：2.0
# 範例：0.5, 1.0, 2.0, 4.0
CPU_LIMIT=2.0

# CPU 保留（容器保證可用的最小 CPU）
# 預設：0.5
CPU_RESERVE=0.5

# ===========================================
# 🏥 健康檢查配置
# ===========================================

# 健康檢查間隔（多久檢查一次服務狀態）
# 預設：30s
HEALTHCHECK_INTERVAL=30s

# 健康檢查超時（檢查請求的最長等待時間）
# 預設：10s
HEALTHCHECK_TIMEOUT=10s

# 健康檢查重試次數（連續失敗多少次視為不健康）
# 預設：3
HEALTHCHECK_RETRIES=3

# 健康檢查啟動寬限期（容器啟動後多久開始檢查）
# 預設：40s（給服務足夠的啟動時間）
HEALTHCHECK_START_PERIOD=40s

# ===========================================
# 📝 日誌配置
# ===========================================

# 日誌文件最大大小（超過後會輪轉）
# 預設：10m (10MB)
# 範例：1m, 10m, 100m
LOG_MAX_SIZE=10m

# 日誌文件最大數量（保留多少個歷史日誌文件）
# 預設：3
# 範例：1, 3, 5, 10
LOG_MAX_FILE=3

# ===========================================
# 🤖 OpenAI 配置（可選 - 用於高品質 OCR）
# ===========================================
# 如果不使用 OpenAI 視覺模型，保持空白即可

# OpenAI API Key
# 獲取方式：https://platform.openai.com/api-keys
# 範例：OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx
OPENAI_API_KEY=

# OpenAI API Base URL
# 預設：https://api.openai.com/v1
# 如果使用兼容 API（如 LocalAI, Ollama），可修改此處
# 範例：OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenAI 模型名稱
# 預設：gpt-4o
# 其他選項：gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o

# ===========================================
# ☁️ Azure Document Intelligence 配置（可選）
# ===========================================
# 如果不使用 Azure，保持空白即可

# Azure Document Intelligence 端點
# 獲取方式：Azure Portal -> Document Intelligence Resource
# 範例：https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=

# Azure Document Intelligence Key
# 獲取方式：Azure Portal -> Keys and Endpoint
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ===========================================
# 🤖 自動轉換服務配置（可選）
# ===========================================
# 自動監控 input/ 目錄並轉換文件到 output/

# 是否啟用自動轉換服務（true/false）
# 預設：true（啟用）
AUTO_ENABLED=true

# 是否啟用 OCR 插件
# 預設：true
AUTO_ENABLE_PLUGINS=true

# OCR 語言（與 DEFAULT_OCR_LANG 相同）
# 預設：chi_tra+eng
AUTO_OCR_LANG=chi_tra+eng

# 是否移動源文件到 .processed 資料夾
# true: 轉換後移動源文件
# false: 保留源文件
# 預設：false
AUTO_MOVE_SOURCE=false

# 監控間隔（秒）
# 預設：5 秒
AUTO_POLL_INTERVAL=5

# 最大重試次數（轉換失敗時）
# 預設：3
AUTO_MAX_RETRIES=3

# 自動轉換服務資源限制
AUTO_MEMORY_LIMIT=1G
AUTO_CPU_LIMIT=1.0
AUTO_MEMORY_RESERVE=256M
AUTO_CPU_RESERVE=0.25

# 自動轉換服務日誌配置
AUTO_LOG_MAX_SIZE=5m
AUTO_LOG_MAX_FILE=2

# ===========================================
# 🎯 快速配置範例
# ===========================================
#
# 【範例 1】基本使用（使用預設值）
# 只需設置：
#   API_PORT=51083
#   DEFAULT_OCR_LANG=chi_tra+eng
#
# 【範例 2】更改端口為 8080
#   API_PORT=8080
#
# 【範例 3】主要處理簡體中文文件
#   DEFAULT_OCR_LANG=chi_sim+eng
#
# 【範例 4】主要處理東南亞文件（泰文、越南文）
#   DEFAULT_OCR_LANG=tha+vie+eng
#
# 【範例 5】增加上傳限制到 100MB
#   MAX_UPLOAD_SIZE=104857600
#
# 【範例 6】使用 OpenAI 高品質 OCR
#   OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx
#   OPENAI_MODEL=gpt-4o
#
# 【範例 7】增加資源限制（高性能需求）
#   MEMORY_LIMIT=4G
#   CPU_LIMIT=4.0
#
# ===========================================
